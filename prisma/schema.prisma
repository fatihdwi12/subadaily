generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Service {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  icon        String?
  createdAt   DateTime @default(now())
}

model TeamMember {
  id       Int     @id @default(autoincrement())
  name     String
  position String
  bio      String?
  photo    String?
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model Atmosphere {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  image       String
  date        DateTime @default(now())
  slug        String   @unique
  status      String   @default("Active")  
}

model Banner {
  id        String   @id @default(cuid())
  filename  String
  order     Int
  status    String   @default("Active")
  createdAt DateTime @default(now())
}

model Team {
  id        String   @id @default(cuid())
  name      String
  role      String
  image     String?
  order     Int      @default(0)
  status    String   @default("Active")
  createdAt DateTime @default(now())
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  content   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Media {
  id        String   @id @default(cuid())
  type      String
  filename  String
  thumbnail String?
  title     String?
  status    String   @default("Active")
  order     Int      @default(0)    // ← tambahkan baris ini
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HeroBanner {
  id        String   @id @default(cuid())
  page      String
  image     String
  status    String   @default("Active")
  createdAt DateTime @default(now())
}

model Gallery {
  id        String   @id @default(cuid())
  type      String   // "image" | "video"
  filename  String
  thumbnail String?  // untuk video preview
  title     String?
  order     Int      @default(0)
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  price       Int
  image       String?
  category    String
  slug        String   @unique
  description String?
  status      String   @default("Active")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}